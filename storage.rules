// ================================================================
// storage.rules — CampusLink Firebase Storage Security Rules
// ================================================================
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: is admin?
    function isAdmin() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true 
             || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Avatars ───────────────────────────────────────────────
    match /avatars/{userId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*')));
    }

    // Allow listing of the avatars folder itself
    match /avatars {
      allow list: if request.auth != null;
    }

    // ── Post Images ───────────────────────────────────────────
    match /posts/{userId}/{fileName} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && (request.resource == null || (request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*')));
    }

    // Allow listing of the posts folder and user subfolders
    match /posts/{allPaths=**} {
      allow list: if request.auth != null;
    }

    // Global Admin Access
    match /{allPaths=**} {
      allow read, write, list: if request.auth != null && isAdmin();
    }
  }
}
