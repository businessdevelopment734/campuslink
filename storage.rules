// ================================================================
// storage.rules — CampusLink Firebase Storage Security Rules
// ================================================================
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatars ───────────────────────────────────────────────
    // Users can only read/write their own avatar
    match /avatars/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024   // max 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Post Images ───────────────────────────────────────────
    match /posts/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
